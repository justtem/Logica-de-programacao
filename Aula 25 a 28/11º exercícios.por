programa {
  funcao inicio() 
  {
    real precoDoProduto , precoFinal , acrecimo

    escreva("o valor do produto e de: ", precoDoProduto)
    leia(precoDoProduto)

   escreva("O acréscimo do produto sera de: ", acrecimo)
   leia(acrecimo)

   precoFinal = precoDoProduto + acrecimo

   escreva("o valor final do seu produto com acréscimo sera de : ", precoFinal)
  }
}
