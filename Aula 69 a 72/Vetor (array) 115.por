programa {
  funcao inicio() {
    inteiro numero[4] = {10,15,20,25}
    inteiro soma, multi, divi

    soma = numero[0] + numero[3]
    escreva("A soma e de ", soma)

    multi = numero[1] * numero[2]
    escreva("\n A multiplicação e de ", multi)

    divi = numero[2] / numero[0] 
    escreva("\n A divisão e de ", divi) 
   }
}
