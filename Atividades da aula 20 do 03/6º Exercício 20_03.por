programa {
  funcao inicio() 
  {
    cadeia produto = "arroz"
    inteiro codigo = 12
    real preco = 25.99
    logico disponivel 
    disponivel = verdadeiro

    escreva("Produto: ", produto , "\n")
    escreva("Codigo: ", codigo, "\n")
    escreva("real: ", preco, "\n")
    escreva("Logico: ", disponivel, "\n")
  }
}
