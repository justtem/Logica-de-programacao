programa {
  funcao inicio() 
  {
    
   inteiro idade = 18
   real altura = 1.78
   logico alunoAtivo = verdadeiro
   caracter sexo = 'M'
   cadeia nomeCompleto = "Luis Miguel"
  
   escreva("Nome: ", nomeCompleto, "\n")
   escreva("Idade: ", idade, "\n")
   escreva("Altura: ", altura, "\n")
   escreva("Aluno Ativo:", alunoAtivo, "\n")
   escreva("Sexo: ", sexo, "\n")
  }
}
