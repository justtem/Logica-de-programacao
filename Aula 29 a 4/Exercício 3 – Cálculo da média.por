programa
{
    funcao inicio()
    {
        real n1, n2, media
        // leia(n1)
        escreva("Qual a primeira nota do aluno?: ")
        leia(n1) 
        
        // leia(n2)
        escreva("Qual a segunda nota do aluno?: ")
