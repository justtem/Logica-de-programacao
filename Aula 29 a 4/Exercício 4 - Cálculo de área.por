programa
{
    funcao inicio()
    { 
        real largura, altur , area
        
        escreva("Qual a largura da área?: ") //leia(largura)
        leia(largura)

        escreva("Qual a altura da área?: ") //leia(altura)
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
}
